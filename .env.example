# Real Elite Contracting — environment variables
# Copy to .env.local for local dev; set the same keys in Vercel
# (Settings -> Environment Variables) for production + preview.

# -----------------------------------------------------------------------------
# REQUIRED — the estimate form 500s without this in production.
# -----------------------------------------------------------------------------

# Resend API key — powers the /api/estimate POST endpoint.
# Get one at https://resend.com/api-keys
RESEND_API_KEY=

# Optional override for where estimate emails are delivered.
# Defaults to info@realelitecontracting.com if unset.
ESTIMATE_TO_EMAIL=


# -----------------------------------------------------------------------------
# OPTIONAL — measurement layer. Pages render fine without these; the
# Microsoft Clarity + GTM scripts simply don't load until they're set.
# GA4 (G-W9QH965H3Y) is hardcoded in src/app/layout.tsx and works
# without any env var.
# -----------------------------------------------------------------------------

# Google Tag Manager container ID. Format: GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=

# Microsoft Clarity project ID. Find at https://clarity.microsoft.com/projects
NEXT_PUBLIC_CLARITY_ID=

# Google API key — powers the Instant Roof Quote tool (/instant-roof-quote).
# Used server-side to geocode an address and pull roof area from the
# Google Solar API. Without it, the tool still works — it just skips the
# satellite measurement and asks the homeowner a couple of quick questions.
# Setup steps are in docs/DEPLOYMENT_CHECKLIST.md (section 5).
GOOGLE_SOLAR_API_KEY=


# -----------------------------------------------------------------------------
# OPTIONAL — Speed-to-lead SMS. The owner gets an instant text the moment
# a qualified lead submits the form. Research shows the first contractor
# to reach a homeowner wins ~70% of jobs. ALL FOUR vars must be set or
# the SMS step is silently skipped (email still works on its own).
# Full setup guide: docs/SPEED_TO_LEAD_SETUP.md
# -----------------------------------------------------------------------------

# Twilio Account SID (starts with "AC...") — Twilio Console > Account Info
TWILIO_ACCOUNT_SID=

# Twilio Auth Token — Twilio Console > Account Info (click "View")
TWILIO_AUTH_TOKEN=

# Twilio phone number to send FROM. Format: +1XXXXXXXXXX (E.164).
# Buy one in Twilio Console > Phone Numbers > Buy a Number (~$1.15/mo).
TWILIO_FROM_NUMBER=

# Owner's phone number to send TO. Format: +1XXXXXXXXXX (E.164).
# Verify it in Twilio Console > Phone Numbers > Verified Caller IDs
# while on the free trial.
TWILIO_TO_NUMBER=


# -----------------------------------------------------------------------------
# OPTIONAL — durable rate limiting for the lead APIs (/api/estimate,
# /api/roof-estimate). Without these, limits are tracked per serverless
# instance in memory (still works, just softer under heavy traffic).
# Create a free Redis database at https://console.upstash.com and copy
# the REST URL + token from the database's "REST API" section.
# -----------------------------------------------------------------------------

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# -----------------------------------------------------------------------------
# OPTIONAL — review-request engine (/review-request internal tool).
# Texts customers a Google review link when a job wraps. Requires the
# Twilio vars above. Full guide: docs/REVIEW_ENGINE_SETUP.md
# -----------------------------------------------------------------------------

# Shared secret protecting the tool. Pick any long random string and
# keep it private — anyone with this key can send texts from your number.
ADMIN_TOOLS_KEY=

# Direct "write a review" link. Find your Place ID at
# https://developers.google.com/maps/documentation/places/web-service/place-id
# and use: https://search.google.com/local/writereview?placeid=YOUR_PLACE_ID
# Falls back to the Google profile share link in src/lib/constants.ts.
GOOGLE_REVIEW_LINK=
