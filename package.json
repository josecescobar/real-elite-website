{
  "name": "real-elite-website",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "optimize": "node scripts/optimize-images.mjs",
    "generate:projects": "node scripts/generate-projects-registry.mjs",
    "prebuild": "node scripts/generate-projects-registry.mjs && node scripts/optimize-images.mjs",
    "build": "next build",
    "postbuild": "next-sitemap",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.577.0",
    "next": "^16.2.9",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@tailwindcss/postcss": "^4.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.7.0",
    "eslint-config-next": "^16.2.10",
    "jsdom": "^29.0.1",
    "next-sitemap": "^4.2.3",
    "postcss": "^8.5.20",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
